#!/bin/bash
# Install bladerunner with dependencies
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/.../install/bladerunner | bash && \
#     eval "$(brew shellenv)"
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

abort() { echo -e "${RED}Error:${NC} ${1}" >&2; exit 1; }
info() { echo -e "${GREEN}==>${NC} ${1}"; }
warn() { echo -e "${YELLOW}Warning:${NC} ${1}"; }

[[ "$OSTYPE" == "darwin"* ]] || abort "macOS only"

# Setup Homebrew PATH
if [[ -x "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

command -v brew &>/dev/null || abort "Homebrew required. Install: https://brew.sh"

# Warn if bladerunner is running (upgrade may need restart)
if command -v br &>/dev/null && br status &>/dev/null 2>&1; then
    if brew outdated bladerunner &>/dev/null 2>&1; then
        warn "Bladerunner is running and may be upgraded. You might need to restart it afterward."
    fi
fi

# Detect fresh install vs upgrade
IS_UPGRADE=false
if brew list stuffbucket/tap/bladerunner &>/dev/null 2>&1; then
    IS_UPGRADE=true
fi

# Install bladerunner (formula includes bladerunner dependency)
if $IS_UPGRADE; then
    info "Upgrading bladerunner..."
    brew upgrade stuffbucket/tap/bladerunner < /dev/null
else
    info "Installing bladerunner..."
    brew install stuffbucket/tap/bladerunner < /dev/null
fi

echo ""
if $IS_UPGRADE; then
    info "bladerunner upgraded successfully (•‿•)"
else
    info "Bladerunner installed successfully (•‿•)"
    echo ""
    info "To use immediately, run:"
    echo ""
    echo "  eval \"\$(brew shellenv)\""
    echo ""
    echo "Or add to your shell profile:"
    if [[ -x "/opt/homebrew/bin/brew" ]]; then
        echo "  echo 'eval \"\$(/opt/homebrew/bin/brew shellenv)\"' >> ~/.zprofile"
    else
        echo "  echo 'eval \"\$(/usr/local/bin/brew shellenv)\"' >> ~/.zprofile"
    fi
fi
echo ""
echo "==> Next steps"
echo ""
echo "Start bladerunner:"
echo "  br start"
echo ""
echo "Then run:"
echo "  br --help"
